# ==========================================
# VARIÁVEIS DE AMBIENTE - UEFS DOCMANAGER
# ==========================================

# Banco de Dados
DATABASE_URL=postgresql://usuario:senha@localhost:5432/uefs_docmanager

# JWT Autenticação
JWT_SECRET=sua_chave_secreta_aqui
JWT_REFRESH_SECRET=sua_chave_refresh_aqui
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Configurações Gerais
PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Credenciais Iniciais de Administrador (Seed)
# Estes dados são usados para criar o primeiro administrador
ADMIN_NAME="Nome do Administrador"
ADMIN_EMAIL=admin@uefs.br
ADMIN_PASSWORD=SenhaInicial123
ADMIN_CPF=00000000000
ADMIN_TELEFONE=75999999999

# Upload de Arquivos (Tamanho Max: 10MB)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Serviços de Mail (Convocação / Avaliação SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=seu_usuario
SMTP_PASS=sua_senha
SMTP_FROM="UEFS DocManager <no-reply@uefs.br>"
